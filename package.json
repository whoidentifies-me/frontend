{
  "name": "wim-frontend",
  "type": "module",
  "scripts": {
    "prebuild": "npm run api:generate",
    "prebuild:spa": "npm run api:generate",
    "predev": "npm run api:generate",
    "predev:spa": "npm run api:generate",
    "dev": "vinxi dev",
    "dev:spa": "vinxi dev --config app.config.spa.ts",
    "build": "vinxi build",
    "build:spa": "vinxi build --config app.config.spa.ts",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "start": "vinxi start",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "lint:css": "stylelint \"src/**/*.css\" --max-warnings 0",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "prepare": "husky",
    "api:fetch": "curl -o openapi.yaml https://api.stage.whoidentifies.me/api/v1/openapi.yaml",
    "api:generate": "orval"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.34.1",
    "@fontsource-variable/montserrat": "^5.2.8",
    "@fontsource-variable/open-sans": "^5.2.7",
    "@solid-primitives/i18n": "^2.2.1",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.4",
    "@solidjs/start": "^1.3.2",
    "solid-icons": "^1.2.0",
    "solid-js": "^1.9.5",
    "typescript": "^5.9.3",
    "vinxi": "^0.5.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@tailwindcss/vite": "^4.0.7",
    "autoprefixer": "^10.4.21",
    "browserslist-config-baseline": "^0.5.0",
    "daisyui": "^5.5.5",
    "eslint": "^9.37.0",
    "eslint-plugin-compat": "^6.0.2",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "orval": "^8.5.3",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "tailwindcss": "^4.0.7",
    "typescript-eslint": "^8.45.0",
    "vite-imagetools": "9.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{md,json}": [
      "prettier --write"
    ]
  }
}
