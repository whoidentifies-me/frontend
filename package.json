{
  "name": "wim-frontend",
  "type": "module",
  "scripts": {
    "dev": "vinxi dev",
    "build": "tsc --noEmit --skipLibCheck && vinxi build",
    "start": "vinxi start",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "prepare": "husky"
  },
  "dependencies": {
    "@solidjs/router": "^0.15.0",
    "@solidjs/start": "^1.1.0",
    "open-props": "^1.7.16",
    "solid-js": "^1.9.5",
    "typescript": "^5.9.3",
    "vinxi": "^0.5.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@tailwindcss/vite": "^4.0.7",
    "eslint": "^9.37.0",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.0.7",
    "typescript-eslint": "^8.45.0"
  },
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  }
}
