{
  "name": "wim-frontend",
  "type": "module",
  "scripts": {
    "dev": "vinxi dev",
    "build": "vinxi build",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "start": "vinxi start",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource/anton": "^5.2.7",
    "@kobalte/core": "^0.13.11",
    "@solid-primitives/i18n": "^2.2.1",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.0",
    "@solidjs/start": "^1.1.0",
    "open-props": "^1.7.16",
    "solid-icons": "^1.1.0",
    "solid-js": "^1.9.5",
    "typescript": "^5.9.3",
    "vinxi": "^0.5.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@tailwindcss/vite": "^4.0.7",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.8.31",
    "browserslist-config-baseline": "^0.5.0",
    "eslint": "^9.37.0",
    "eslint-plugin-compat": "^6.0.2",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "tailwindcss": "^4.0.7",
    "typescript-eslint": "^8.45.0"
  },
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{md,json}": [
      "prettier --write"
    ]
  }
}
